<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ReportD</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio,container-queries"></script>

    <style>
      body { max-width: 1200px; }
    </style>

    <script type="module">
      import { onCLS, onINP, onLCP, onFCP, onTTFB } from 'https://unpkg.com/web-vitals@5?module';

      function sendToAnalytics(metric) {
        const body = JSON.stringify(metric);
        (navigator.sendBeacon && navigator.sendBeacon('https://reportd.natwelch.com/analytics/resume', body)) ||
          fetch('https://reportd.natwelch.com/analytics/resume', { body, method: 'POST', keepalive: true });
      }

      onCLS(sendToAnalytics);
      onFCP(sendToAnalytics);
      onINP(sendToAnalytics);
      onLCP(sendToAnalytics);
      onTTFB(sendToAnalytics);
    </script>
  </head>

  <body class="mx-auto p-6 md:p-24 bg-black text-white">

    <header class="mb-10">
      <h1 class="text-3xl font-bold">ReportD</h1>
      <p class="text-gray-500">
        Browser reporting and Web Vitals dashboard.
        <a class="underline" href="https://github.com/icco/reportd">Source on GitHub</a>.
      </p>
    </header>

    <main>
      <div id="services" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
        {{range $element := .Services}}
        <a href="/view/{{ $element }}" class="block rounded-lg border border-gray-700 p-4 hover:border-gray-500 transition-colors" data-service="{{ $element }}">
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-lg font-medium">{{ $element }}</h2>
            <span class="text-gray-500 text-sm">&rarr;</span>
          </div>
          <div class="flex gap-2 flex-wrap" id="health-{{ $element }}">
          </div>
        </a>
        {{end}}
      </div>
    </main>

    <script>
      const THRESHOLDS = {
        LCP:  { good: 2500, poor: 4000 },
        CLS:  { good: 0.1,  poor: 0.25 },
        INP:  { good: 200,  poor: 500 },
        FCP:  { good: 1800, poor: 3000 },
        TTFB: { good: 800,  poor: 1800 },
      };

      const CWV_METRICS = ['LCP', 'CLS', 'INP'];

      function ratingInfo(metric, value) {
        const t = THRESHOLDS[metric];
        if (!t) return { cls: 'bg-gray-800 text-gray-400', label: metric };
        if (value <= t.good) return { cls: 'bg-green-900/50 text-green-400', label: metric };
        if (value <= t.poor) return { cls: 'bg-amber-900/50 text-amber-400', label: metric };
        return { cls: 'bg-red-900/50 text-red-400', label: metric };
      }

      try {
        const health = JSON.parse({{ .HealthJSON }});
        Object.entries(health).forEach(([service, metrics]) => {
          const container = document.getElementById('health-' + service);
          if (!container) return;

          const cwvMetrics = metrics.filter(m => CWV_METRICS.includes(m.metric));
          if (!cwvMetrics.length) {
            container.innerHTML = '<span class="text-xs text-gray-600">No vitals data</span>';
            return;
          }

          container.innerHTML = cwvMetrics.map(m => {
            const r = ratingInfo(m.metric, m.p75);
            return `<span class="text-xs px-1.5 py-0.5 rounded ${r.cls}">${m.metric}</span>`;
          }).join('');
        });
      } catch(e) {
        console.error('Error parsing health data:', e);
      }
    </script>
  </body>

</html>
